{
  "manifest_version": 3,
  "name": "Sam's Chat Flair",
  "version": "1.0.2",
  "description": "See custom emojis and leaderboard flair in Sam's Kick chat. Earned through sam.sucks/shop",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://kick.com/sam*",
    "https://shimmering-learning-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://kick.com/sam*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "samschatflair@extension",
      "strict_min_version": "128.0"
    }
  }
}